{
  "name": "@jinn-network/autopilot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "bin": {
    "jinn-merge-batch": "./bin/jinn-merge-batch.ts",
