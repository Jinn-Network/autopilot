{
  "name": "@jinn-network/autopilot",
  "version": "0.1.0",
  "description": "A self-hosted GitHub lifecycle engine for open-source maintainers",
  "license": "MIT",
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": ">=22 <23"
  },
  "bin": "./dist/autopilot.js",
  "files": [
    "dist/autopilot.js",
    "assets",
    "schemas",
    "templates",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "node scripts/build-distribution.mjs",
    "verify:dist": "node scripts/verify-distribution.mjs",
    "prepack": "yarn build && yarn verify:dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "pressure": "tsx scripts/run-pressure-suite.ts",
    "autopilot": "tsx scripts/run-autopilot-v2.ts",
    "autopilot:v2": "tsx scripts/run-autopilot-v2.ts",
    "autopilot:legacy": "tsx scripts/run-autopilot.ts",
    "autopilot:capability-probe": "tsx scripts/probe-autopilot-v2-capabilities.ts",
    "paint-board": "tsx scripts/paint-board.ts",
    "merge:batch": "tsx bin/jinn-merge-batch.ts",
    "stage:run": "tsx bin/jinn-run-stage.ts",
    "triage:check": "tsx bin/jinn-triage-check.ts"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "esbuild": "^0.28.0",
    "tsx": "^4.23.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  }
}
